# CogOS configuration
#
# provider: the global fallback for agents that don't have a specific config.
# Use "host" (or omit) to rely on the AI already running cog — saves tokens
# when cog is invoked via MCP (Claude Code, Cursor, opencode, Gemini CLI, etc.)
#
provider: host

# Per-agent model overrides.
# Each agent role can declare its own provider / model / api_key / base_url.
# If a role is omitted here it inherits the global provider above.
#
# Known roles: planner, document_writer, executor, researcher,
#              coder, reviewer, critic, tester, documenter,
#              optimizer, security, architect
#
agents:
  # planner — decomposes tasks into steps (cheap, use a small model)
  planner:
    provider: openai          # openai | anthropic
    model: gpt-4o-mini
    api_key: YOUR_KEY_HERE
    # base_url: https://api.openai.com/v1   # optional, for custom endpoints

  # document_writer — generates docs, summaries, reports (cheap model is fine)
  document_writer:
    provider: openai
    model: gpt-4o-mini
    api_key: YOUR_KEY_HERE

  # executor — the main agent that writes / runs code
  # executor:
  #   provider: openai
  #   model: gpt-4o
  #   api_key: YOUR_KEY_HERE

  # researcher — web search + analysis
  # researcher:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # coder — writes implementation code
  # coder:
  #   provider: openai
  #   model: gpt-4o
  #   api_key: YOUR_KEY_HERE

  # reviewer — reviews and critiques code
  # reviewer:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # critic — finds flaws and improvements
  # critic:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # tester — tests and validates output
  # tester:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # documenter — writes inline documentation
  # documenter:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # optimizer — optimizes performance
  # optimizer:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # security — security analysis
  # security:
  #   provider: openai
  #   model: gpt-4o-mini
  #   api_key: YOUR_KEY_HERE

  # architect — system design decisions
  # architect:
  #   provider: openai
  #   model: gpt-4o
  #   api_key: YOUR_KEY_HERE

# --- Other settings ---
memory_backend: sqlite        # sqlite | mem0
modules_path: modules
memory_path: cog_memory.db
log_level: INFO
max_agent_iterations: 20

# Max characters of expertise text returned per cog_run / cog_chat call.
# ~6000 chars ≈ 1500 tokens. Raise if you want richer context per call;
# lower if you're hitting context limits. Set COG_MAX_EXPERTISE_CHARS to override.
max_expertise_chars: 6000
